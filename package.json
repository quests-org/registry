{
  "name": "@quests/directory",
  "version": "0.0.0",
  "description": "Quests Directory",
  "repository": {
    "type": "git",
    "url": "https://github.com/finalpointco/directory"
  },
  "author": {
    "name": "Finalpoint",
    "email": "oss@finalpoint.co"
  },
  "type": "module",
  "files": [],
  "scripts": {
    "knip": "knip",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run check:types",
    "typecheck:all": "turbo run build --dry-run",
    "check": "turbo run lint check:types test syncpack:lint knip check-gitignore cspell cspell:unused validate-skills check:format",
    "check:format": "prettier --check .",
    "fix:format": "prettier --write .",
    "fix:unused-words": "cspell-check-unused-words --fix",
    "test": "turbo run test",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "create-app": "tsx scripts/create-app.ts",
    "apply-block": "tsx scripts/apply-block.ts",
    "list-blocks": "tsx scripts/list-blocks.ts",
    "check-gitignore": "tsx scripts/check-gitignore.ts",
    "validate-skills": "tsx scripts/validate-skills.ts",
    "syncpack": "syncpack",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "cspell": "cspell \"**/*\" --no-progress",
    "cspell:fix": "cspell \"**/*\" --no-progress --fix",
    "cspell:unused": "cspell-check-unused-words"
  },
  "devDependencies": {
    "@cspell/dict-bash": "^4.2.1",
    "@cspell/dict-css": "^4.0.18",
    "@cspell/dict-html": "^4.0.12",
    "@cspell/dict-node": "^5.0.8",
    "@cspell/dict-npm": "^5.2.19",
    "@cspell/dict-typescript": "^3.2.3",
    "@types/node": "22.19.2",
    "cspell": "^9.2.2",
    "cspell-check-unused-words": "^1.5.4",
    "ignore": "^7.0.5",
    "jscodeshift": "^17.3.0",
    "knip": "^5.86.0",
    "prettier": "^3.8.1",
    "syncpack": "14.2.0",
    "tokenx": "^1.3.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.21.1"
  },
  "publishConfig": {
    "provenance": true
  }
}
