{
  "name": "@quests/directory",
  "version": "0.0.0",
  "description": "Quests Directory",
  "repository": {
    "type": "git",
    "url": "https://github.com/finalpointco/directory"
  },
  "author": {
    "name": "Finalpoint",
    "email": "oss@finalpoint.co"
  },
  "type": "module",
  "files": [],
  "scripts": {
    "check-and-test": "turbo run check:types test check:syncpack check:knip check:gitignore check:spelling check:unused-words check:skills check:format --ui tui --continue=dependencies-successful --output-logs errors-only",
    "check:format": "prettier --check .",
    "check:gitignore": "tsx scripts/check-gitignore.ts",
    "check:knip": "knip",
    "check:skills": "tsx scripts/validate-skills.ts",
    "check:spelling": "cspell \"**/*\" --no-progress",
    "check:syncpack": "syncpack lint",
    "check:types": "turbo run check:types",
    "check:unused-words": "cspell-check-unused-words",
    "fix:format": "prettier --write .",
    "fix:spelling": "cspell \"**/*\" --no-progress --fix",
    "fix:syncpack": "syncpack fix",
    "fix:unused-words": "cspell-check-unused-words --fix",
    "test": "turbo run test",
    "create-app": "tsx scripts/create-app.ts",
    "apply-block": "tsx scripts/apply-block.ts",
    "list-blocks": "tsx scripts/list-blocks.ts",
    "syncpack": "syncpack"
  },
  "devDependencies": {
    "@cspell/dict-bash": "^4.2.1",
    "@cspell/dict-css": "^4.0.18",
    "@cspell/dict-html": "^4.0.12",
    "@cspell/dict-node": "^5.0.8",
    "@cspell/dict-npm": "^5.2.19",
    "@cspell/dict-typescript": "^3.2.3",
    "@types/node": "22.19.2",
    "cspell": "^9.2.2",
    "cspell-check-unused-words": "^1.5.4",
    "ignore": "^7.0.5",
    "jscodeshift": "^17.3.0",
    "knip": "^5.86.0",
    "prettier": "^3.8.1",
    "syncpack": "14.2.0",
    "tokenx": "^1.3.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.21.1"
  },
  "publishConfig": {
    "provenance": true
  }
}
